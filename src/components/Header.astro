---
import config from 'virtual:starlight/user-config';
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import SocialIcons from 'virtual:starlight/components/SocialIcons';
import ThemeSelect from 'virtual:starlight/components/ThemeSelect';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';

const path = Astro.url.pathname;
const navItems = [
  { label: 'Home',     href: '/',                   active: path === '/' || path === '' },
  { label: 'Packages', href: '/packages/overview/',  active: path.startsWith('/packages') },
  { label: 'Blog',     href: '/blog/',               active: path.startsWith('/blog') },
  { label: 'About',    href: '/about/',              active: path.startsWith('/about') },
];
---

<div class="header sl-flex">
  <div class="title-wrapper sl-flex">
    <SiteTitle {...Astro.props} />
  </div>
  <nav class="mobile-site-nav sl-flex md:sl-hidden" aria-label="Main">
    {navItems.map(({ label, href, active }) => (
      <a href={href} class:list={['nav-link', 'mobile-nav-link', { active }]}>{label}</a>
    ))}
  </nav>
  <nav class="site-nav sl-hidden md:sl-flex" aria-label="Main">
    {navItems.map(({ label, href, active }) => (
      <a href={href} class:list={['nav-link', { active }]}>{label}</a>
    ))}
  </nav>
  <div class="search-wrapper sl-hidden md:sl-flex print:hidden">
    {shouldRenderSearch && <Search {...Astro.props} />}
  </div>
  <div class="right-group sl-hidden md:sl-flex print:hidden">
    <div class="sl-flex social-icons">
      <SocialIcons {...Astro.props} />
    </div>
    <ThemeSelect {...Astro.props} />
    <LanguageSelect {...Astro.props} />
  </div>
</div>

<style>
  /* Stable flex layout — no extra padding (outer <header> already has it) */
  .header {
    align-items: center;
    height: 100%;
    gap: 0.75rem;
  }

  .title-wrapper {
    flex-shrink: 0;
    overflow: clip;
    padding: 0.25rem;
    margin: -0.25rem;
  }

  .site-nav {
    flex-shrink: 0;
    gap: 0.125rem;
    align-items: center;
  }

  .mobile-site-nav {
    flex: 1;
    min-width: 0;
    gap: 0.35rem;
    align-items: center;
    overflow-x: auto;
    padding-inline-end: 0.15rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .mobile-site-nav::-webkit-scrollbar {
    display: none;
  }

  /* Search takes remaining space but is capped so right-group goes to far right */
  .search-wrapper {
    flex: 1;
    min-width: 8rem;
    max-width: 24rem;
    justify-content: center;
  }

  /* Push all the way to the right edge */
  .right-group {
    flex-shrink: 0;
    gap: 1rem;
    align-items: center;
    margin-inline-start: auto;
  }

  .social-icons {
    gap: 1rem;
    align-items: center;
  }

  .social-icons::after {
    content: '';
    height: 2rem;
    border-inline-end: 1px solid rgba(255, 255, 255, 0.3);
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 600;
    font-size: 0.875rem;
    padding: 0.35rem 0.7rem;
    border-radius: 0.35rem;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s, color 0.15s;
  }

  .mobile-nav-link {
    flex-shrink: 0;
    font-size: 0.82rem;
    padding: 0.3rem 0.62rem;
  }

  .nav-link:hover,
  .nav-link.active {
    background-color: rgba(255, 255, 255, 0.18);
    color: white;
    text-decoration: none;
  }
</style>
